{
  "name": "habit-game-desktop",
  "private": true,
  "version": "1.0.36",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "app": "vite build && electron .",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "simple-icons": "^16.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "build": {
    "appId": "com.habitgame.tracker",
    "productName": "Habit Game",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "carryon-11",
        "repo": "Habit-tracker",
        "releaseType": "release"
      }
    ]
  }
}
